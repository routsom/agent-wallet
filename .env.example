# agent-wallet environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# SQLite database path (default: ~/.agent-wallet/ledger.db)
# AGENT_WALLET_DB=~/.agent-wallet/ledger.db

# Custom pricing manifest path (default: bundled pricing.yaml)
# AGENT_WALLET_PRICING=/path/to/custom-pricing.yaml

# Set to 1 to disable all budget interception (useful for testing)
# AGENT_WALLET_DISABLED=0

# --- Telegram kill switch / alerts ---
# Create a bot at https://t.me/BotFather and get the token.
# Get your chat ID by messaging @userinfobot.
# TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJkkLLmmNNoopp
# TELEGRAM_CHAT_ID=987654321

# --- Discord alerts ---
# Create a webhook in your Discord server settings.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000000000000000/xxxx
